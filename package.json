{
  "name": "ux-design-studio-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --filter @uxds/studio dev",
    "dev:standalone": "pnpm --filter @uxds/studio dev",
    "dev:host": "pnpm --filter @uxds/host dev",
    "build": "pnpm -r --if-present build",
    "build:studio": "pnpm --filter @uxds/studio build",
    "build:host": "pnpm --filter @uxds/host build",
    "preview": "pnpm --filter @uxds/studio preview",
    "lint": "pnpm -r --if-present lint && eslint . --config eslint.config.js",
    "typecheck": "pnpm -r --if-present typecheck && tsc -p tsconfig.scripts.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "pnpm -r --if-present test && vitest run --config vitest.scripts.config.ts",
    "test:watch": "pnpm --filter @uxds/studio test:watch",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "ci:verify-signatures": "tsx scripts/ci/verify-commit-signatures.ts",
    "plan:validate": "tsx scripts/import-github-project.ts --validate-only",
    "github:import:dry": "tsx scripts/import-github-project.ts --dry-run",
    "github:import": "tsx scripts/import-github-project.ts",
    "github:import:verbose": "tsx scripts/import-github-project.ts --verbose",
    "agent:validate": "tsx scripts/agent/validate-agent-control.ts",
    "agent:project-status": "tsx scripts/agent/project-status.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
